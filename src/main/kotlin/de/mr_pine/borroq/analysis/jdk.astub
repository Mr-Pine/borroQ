package java.lang;
import de.mr_pine.borroq.qual.mutability.*;
import de.mr_pine.borroq.qual.release.Release;

public class Object {
    @Mutable Object();
}

public class String {
    @Immutable String(@Immutable @Release String original);
}

public class Integer {
    static @Immutable Integer valueOf(int i);
}

package java.util;

public interface List<E> {
    @Mutable E get(@Mutable @Borrow List<E> this, int index);
}